{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Warning",
      "System": "Warning"
    }
  },
  "HomeAssistant": {
    "Url": "ws://192.168.1.XXX:8123/api/websocket",
    "Token": "YOUR_LONG_LIVED_ACCESS_TOKEN",

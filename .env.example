# --- Home Assistant Connection ---
# The WebSocket URL for your HA instance
HA_URL=ws://192.168.1.XXX:8123/api/websocket

# The long-lived access token generated in HA Profile
HA_TOKEN=YOUR_LONG_LIVED_ACCESS_TOKEN_HERE

# --- Audio Configuration ---
# 'true' for Windows, macOS, WSL2, 'false' for Linux
DEBUG_UDP_AUDIO=true

# Name of the audio device (Only used if DEBUG_UDP_AUDIO=false)
AUDIO_DEVICE_NAME="Microphone (USB Audio Device)"

# Buffer duration in seconds
AUDIO_SECONDS_TO_BUFFER=10

# The Home Assistant Entity ID for the Satellite
HA_SATELLITE_ID=assist_satellite.your_satellite_entity_id_here

# Appearance
# Set to 'true' if you see weird blocks instead of emojis in your logs
USE_ASCII_LOGS=false